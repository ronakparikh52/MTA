# Copy this file to backend/.env and fill in real values. The .env file is
# gitignored so secrets stay off GitHub. To deploy to the Raspberry Pi, copy
# the populated .env over via scp:
#   scp backend/.env pi@<pi-ip>:/home/pi/MTA_Schedule/backend/.env

# Required for live bus arrivals (free key from https://register.developer.obanyc.com).
MTA_BUS_API_KEY=

# Optional: shared secret the Matrix Portal sends as X-API-Key. Leave blank for no auth.
MATRIX_API_KEY=

# Optional runtime knobs (defaults shown).
MATRIX_PORT=5000
MATRIX_CACHE_TTL=20
MATRIX_BG_REFRESH=1
MATRIX_PERF_LOG_EVERY=10
